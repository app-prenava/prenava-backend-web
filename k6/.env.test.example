# k6 Test Environment Configuration
# Copy this file to .env.test and fill in your test credentials
# IMPORTANT: Use dedicated test accounts only - NEVER use production credentials

# API Base URL (default: https://prenavabe.cloud/api)
API_URL=https://prenavabe.cloud/api

# Test User Credentials (create a dedicated test account)
TEST_EMAIL=k6-test@example.com
TEST_PASSWORD=TestPassword123!

# Admin User Credentials (for admin endpoint testing)
ADMIN_EMAIL=admin@prenava.test
ADMIN_PASSWORD=AdminPassword123!

# Notes:
# - These credentials should be for TEST accounts only
# - Create test accounts before running load tests
# - Monitor server resources during testing
# - Run tests during off-peak hours
